@model TodoListApp.WebApp.Models.TodoTask
@{
    ViewData["Title"] = "Delete Task";
}

<h1>Delete Task</h1>
<h3>Are you sure you want to delete this task?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@Model.DueDate</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="listId" value="@Model.TodoListId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" asp-route-listId="@Model.TodoListId" class="btn btn-secondary">Back to Tasks</a>
    </form>
</div>
